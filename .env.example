# Stardust local configuration.
#
# Copy this file to `.env` and fill in MODEL_API_KEY. Bun loads `.env`
# automatically for every `bun run` command, so no dotenv import is needed.
# Every value below is optional except MODEL_API_KEY; the defaults shown are the
# ones the code falls back to and are safe for local single-user development.

# ── Model provider (required for real turns) ──────────────────────────────────
# Anthropic API key. Without it the app and run inspector still work, but any
# turn that calls the model — and the `bun run chaos` demo — will fail.
MODEL_API_KEY=

# ── Temporal ──────────────────────────────────────────────────────────────────
# Frontend address of the Temporal dev server.
TEMPORAL_ADDRESS=localhost:7233
# Temporal namespace. `temporal server start-dev` auto-creates `default`. To use
# a different namespace you must also start the server with `--namespace <name>`.
TEMPORAL_NAMESPACE=default
# Port for the Temporal Web UI (started by `bun run temporal:dev`).
TEMPORAL_WEB_PORT=8233

# ── Storage ───────────────────────────────────────────────────────────────────
# SQLite database location. A leading `~` is expanded to your home directory.
DATABASE_URL=file:~/.stardust/stardust.db
# Root directory for spilled tool-output artifacts.
ARTIFACT_DIR=~/.stardust/artifacts
# HMAC secret used to mint/verify local artifact download tokens. The default is
# safe only for local development — override it before exposing the app.
ARTIFACT_TOKEN_SECRET=stardust-local-dev-secret
# Byte length above which tool output is spilled to an artifact instead of being
# returned inline to the model.
TOOL_RESULT_INLINE_LIMIT=8000

# ── Sandbox ───────────────────────────────────────────────────────────────────
# Sandbox provider for tool execution. Only `local-subprocess` exists in the POC.
SANDBOX_PROVIDER=local-subprocess
