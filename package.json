{
	"name": "stardust",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "concurrently --names web,worker --prefix-colors cyan,yellow \"bun run dev:web\" \"bun run dev:worker\"",
		"dev:web": "vite dev",
		"dev:worker": "tsx watch src/worker/main.ts",
		"temporal:dev": "temporal server start-dev --db-filename ~/.stardust/temporal.db --ui-port 8233",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"typecheck:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test:unit": "vitest",
		"test": "bun run test:unit -- --run && bun run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "tsx scripts/db/migrate.ts",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@libsql/client": "^0.17.3",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@temporalio/testing": "^1.18.1",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.8",
		"build-temporal-workflow": "^0.4.0",
		"concurrently": "^10.0.3",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"eslint-plugin-temporal": "^0.1.0",
		"globals": "^17.6.0",
		"lefthook": "^2.1.9",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@lostgradient/cinder": "^0.4.0",
		"@temporalio/activity": "^1.18.1",
		"@temporalio/client": "^1.18.1",
		"@temporalio/worker": "^1.18.1",
		"@temporalio/workflow": "^1.18.1",
		"better-sqlite3": "^12.11.1"
	},
	"trustedDependencies": [
		"@swc/core",
		"better-sqlite3",
		"esbuild",
		"lefthook",
		"protobufjs"
	]
}
